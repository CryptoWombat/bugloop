{
  "name": "@bugloop/adapter-supabase",
  "version": "0.1.3",
  "description": "Supabase storage and auth adapter for Bugloop",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CryptoWombat/bugloop.git",
    "directory": "packages/adapter-supabase"
  },
  "keywords": [
    "bugloop",
    "supabase",
    "adapter",
    "storage"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@bugloop/core": "workspace:*"
  },
  "peerDependencies": {
    "@supabase/supabase-js": ">=2.40.0"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "typescript": "^5.8.0"
  }
}
