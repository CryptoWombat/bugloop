{
  "name": "@bugloop/agent-github",
  "version": "0.1.3",
  "description": "GitHub Actions agent trigger for Bugloop auto-fix",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CryptoWombat/bugloop.git",
    "directory": "packages/agent-github"
  },
  "keywords": [
    "bugloop",
    "github-actions",
    "agent",
    "autofix",
    "claude-code"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "workflows"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@bugloop/core": "workspace:*"
  },
  "peerDependencies": {
    "@octokit/rest": ">=20.0.0"
  },
  "peerDependenciesMeta": {
    "@octokit/rest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@octokit/rest": "^21.0.0",
    "typescript": "^5.8.0"
  }
}
