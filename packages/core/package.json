{
  "name": "@bugloop/core",
  "version": "0.1.0",
  "description": "Core triage engine, ticket lifecycle, and agent bridge for Bugloop",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "test": "vitest run"
  },
  "peerDependencies": {
    "ai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "ai": { "optional": true }
  },
  "devDependencies": {
    "ai": "^4.3.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
