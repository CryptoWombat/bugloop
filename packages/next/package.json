{
  "name": "@bugloop/next",
  "version": "0.1.3",
  "description": "Next.js route handlers and React components for Bugloop",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CryptoWombat/bugloop.git",
    "directory": "packages/next"
  },
  "keywords": [
    "bugloop",
    "nextjs",
    "support-widget",
    "react",
    "route-handler"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@bugloop/core": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "ai": ">=4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "ai": "^4.3.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0"
  }
}
